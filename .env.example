# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# Provider: "openai" (direct) or "azure" (Azure OpenAI)
OPENAI_PROVIDER=openai

# --- Direct OpenAI ---
OPENAI_API_KEY=sk-proj-your-key-here

# --- Azure OpenAI ---
# OPENAI_PROVIDER=azure
# AZURE_OPENAI_API_KEY=your-azure-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
# AZURE_OPENAI_DEPLOYMENT=my-realtime-deployment
# AZURE_OPENAI_CHAT_DEPLOYMENT=my-chat-deployment
# AZURE_OPENAI_VISION_DEPLOYMENT=my-vision-deployment
# AZURE_OPENAI_API_VERSION=2025-04-01-preview
