<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BodyCam.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BodyCam"
    xmlns:mainPages="clr-namespace:BodyCam.Pages.Main"
    FlyoutBehavior="Disabled"
    Title="BodyCam">

    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" VerticalOptions="Center" Padding="8,0">
            <Label Text="BodyCam" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
            <Label x:Name="BuildLabel" AutomationId="BuildLabel" Grid.Column="1" FontSize="12"
                   VerticalOptions="Center" Margin="6,0,0,0"
                   TextColor="{AppThemeBinding Light=#999999, Dark=#777777}" />
            
            <!-- Glasses battery widget (M33 Phase 7 Wave 3) -->
            <HorizontalStackLayout Grid.Column="3"
                                   Spacing="4" VerticalOptions="Center"
                                   Margin="12,0"
                                   IsVisible="{Binding GlassesConnected}">
                <Label Text="🕶️" FontSize="16" />
                <Label Text="{Binding GlassesBatteryPct, StringFormat='{0}%'}"
                       FontSize="12"
                       TextColor="{Binding GlassesBatteryColor}" />
                <Label Text="⚡" FontSize="12"
                       IsVisible="{Binding GlassesCharging}" />
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding NavigateToGlassesCommand}" />
                </HorizontalStackLayout.GestureRecognizers>
            </HorizontalStackLayout>

            <Button x:Name="NavIcon" AutomationId="NavIcon" Grid.Column="4" Text="⚙" FontSize="20"
                    Clicked="OnNavIconTapped"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#333333, Dark=#E0E0E0}"
                    Padding="8,0"
                    MinimumHeightRequest="36" MinimumWidthRequest="36" />
        </Grid>
    </Shell.TitleView>

    <ShellContent
        AutomationId="HomeTab"
        Title="Home"
        ContentTemplate="{DataTemplate mainPages:MainPage}"
        Route="MainPage" />

</Shell>
