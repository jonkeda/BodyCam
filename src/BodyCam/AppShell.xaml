<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BodyCam.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BodyCam"
    Title="BodyCam">

    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,Auto,*,Auto" VerticalOptions="Center" Padding="8,0">
            <Label Text="BodyCam" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
            <Label x:Name="BuildLabel" AutomationId="BuildLabel" Grid.Column="1" FontSize="12"
                   VerticalOptions="Center" Margin="6,0,0,0"
                   TextColor="{AppThemeBinding Light=#999999, Dark=#777777}" />
            <Label x:Name="NavIcon" AutomationId="NavIcon" Grid.Column="3" Text="⚙" FontSize="20"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=#333333, Dark=#E0E0E0}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNavIconTapped" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>
    </Shell.TitleView>

    <TabBar>
        <Tab>
            <ShellContent
                AutomationId="SetupTab"
                Title="Setup"
                ContentTemplate="{DataTemplate local:SetupPage}"
                Route="SetupPage" />
        </Tab>
        <Tab>
            <ShellContent
                AutomationId="HomeTab"
                Title="Home"
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>
        <Tab>
            <ShellContent
                AutomationId="SettingsTab"
                Title="Settings"
                ContentTemplate="{DataTemplate local:SettingsPage}"
                Route="SettingsPage" />
        </Tab>
    </TabBar>

</Shell>
