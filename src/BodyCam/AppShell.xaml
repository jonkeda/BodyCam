<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BodyCam.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BodyCam"
    xmlns:mainPages="clr-namespace:BodyCam.Pages.Main"
    xmlns:settingsPages="clr-namespace:BodyCam.Pages.Settings"
    xmlns:setupPages="clr-namespace:BodyCam.Pages.Setup"
    Title="BodyCam">

    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,Auto,*,Auto" VerticalOptions="Center" Padding="8,0">
            <Label Text="BodyCam" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
            <Label x:Name="BuildLabel" AutomationId="BuildLabel" Grid.Column="1" FontSize="12"
                   VerticalOptions="Center" Margin="6,0,0,0"
                   TextColor="{AppThemeBinding Light=#999999, Dark=#777777}" />
            <Button x:Name="NavIcon" AutomationId="NavIcon" Grid.Column="3" Text="⚙" FontSize="20"
                    Clicked="OnNavIconTapped"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#333333, Dark=#E0E0E0}"
                    Padding="8,0"
                    MinimumHeightRequest="36" MinimumWidthRequest="36" />
        </Grid>
    </Shell.TitleView>

    <TabBar>
        <Tab>
            <ShellContent
                AutomationId="SetupTab"
                Title="Setup"
                ContentTemplate="{DataTemplate setupPages:SetupPage}"
                Route="SetupPage" />
        </Tab>
        <Tab>
            <ShellContent
                AutomationId="HomeTab"
                Title="Home"
                ContentTemplate="{DataTemplate mainPages:MainPage}"
                Route="MainPage" />
        </Tab>
        <Tab>
            <ShellContent
                AutomationId="SettingsTab"
                Title="Settings"
                ContentTemplate="{DataTemplate settingsPages:SettingsPage}"
                Route="SettingsPage" />
        </Tab>
    </TabBar>

</Shell>
