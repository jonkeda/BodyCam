<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels.Settings"
             x:Class="BodyCam.Pages.Settings.DeviceSettingsPage"
             x:DataType="vm:DeviceViewModel"
             Shell.TabBarIsVisible="False"
             Title="Devices">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="10" MaximumWidthRequest="500">

            <!-- Auto-switch notification -->
            <Frame Padding="8" CornerRadius="8"
                   BackgroundColor="{AppThemeBinding Light={StaticResource InfoSurface}, Dark={StaticResource InfoSurfaceDark}}"
                   IsVisible="{Binding HasAutoSwitchMessage}"
                   AutomationId="AutoSwitchNotification">
                <Label Text="{Binding AutoSwitchMessage}"
                       FontSize="12" FontAttributes="Italic"
                       TextColor="{AppThemeBinding Light={StaticResource InfoText}, Dark={StaticResource InfoTextDark}}" />
            </Frame>

            <!-- Connect Device button -->
            <Button Text="+ Connect Device"
                    Command="{Binding ConnectDeviceCommand}"
                    Style="{StaticResource SettingsOutlineButton}"
                    AutomationId="ConnectDeviceButton" />

            <!-- Connected Devices -->
            <Label Text="CONNECTED DEVICES" Style="{StaticResource SettingsSectionHeader}"
                   SemanticProperties.HeadingLevel="Level1" />

            <CollectionView ItemsSource="{Binding ConnectedDevices}"
                            AutomationId="ConnectedDevicesList"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <Frame Padding="10" CornerRadius="8"
                           BackgroundColor="{AppThemeBinding Light={StaticResource CardSurface}, Dark={StaticResource CardSurfaceDark}}"
                           BorderColor="{AppThemeBinding Light={StaticResource BorderDefault}, Dark={StaticResource BorderDefaultDark}}"
                           AutomationId="ConnectedDevicesEmptyState">
                        <Label Text="No external devices connected. Phone/Laptop defaults are still available."
                               AutomationId="ConnectedDevicesEmptyStateLabel"
                               Style="{StaticResource SettingsStatusText}" />
                    </Frame>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConnectedDeviceCardViewModel">
                        <Frame Padding="10" Margin="0,0,0,8" CornerRadius="8"
                               BackgroundColor="{AppThemeBinding Light={StaticResource CardSurface}, Dark={StaticResource CardSurfaceDark}}"
                               BorderColor="{AppThemeBinding Light={StaticResource BorderDefault}, Dark={StaticResource BorderDefaultDark}}"
                               AutomationId="ConnectedDeviceCard">
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="8">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleExpandedCommand}" />
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0" Text="{Binding ExpandGlyph}" FontSize="12" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Icon}" FontSize="12" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="{Binding DisplayName}"
                                           AutomationId="ConnectedDeviceCardTitle"
                                           Style="{StaticResource SettingsDeviceHeader}"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="3" Text="{Binding BatteryText}"
                                           IsVisible="{Binding HasBattery}"
                                           Style="{StaticResource SettingsStatusText}"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="4" Text="{Binding ChargingText}"
                                           IsVisible="{Binding IsCharging}"
                                           Style="{StaticResource SettingsStatusText}"
                                           VerticalOptions="Center" />
                                </Grid>

                                <Label Text="{Binding Summary}"
                                       IsVisible="{Binding HasSummary}"
                                       Style="{StaticResource SettingsStatusText}" />

                                <VerticalStackLayout Spacing="6"
                                                     Padding="28,0,0,0"
                                                     IsVisible="{Binding IsExpanded}">
                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding DetailRows}"
                                                         IsVisible="{Binding HasDetails}"
                                                         Spacing="2">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ConnectedDeviceDetailRow">
                                                <Grid ColumnDefinitions="90,*" ColumnSpacing="8">
                                                    <Label Grid.Column="0"
                                                           Text="{Binding Label}"
                                                           Style="{StaticResource SettingsDetailLabel}" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           Style="{StaticResource SettingsDetailValue}" />
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>

                                    <Label Text="{Binding SlotSummary}"
                                           IsVisible="{Binding HasSlotTags}"
                                           Style="{StaticResource SettingsStatusText}" />

                                    <HorizontalStackLayout Spacing="10"
                                                           Margin="0,4,0,0"
                                                           IsVisible="{Binding HasActions}">
                                        <Button Text="Disconnect"
                                                Command="{Binding DisconnectCommand}"
                                                IsVisible="{Binding CanDisconnect}"
                                                Style="{StaticResource SettingsDangerButton}" />
                                        <Button Text="Remove"
                                                Command="{Binding RemoveCommand}"
                                                IsVisible="{Binding CanRemove}"
                                                Style="{StaticResource SettingsOutlineButton}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Source Profile -->
            <VerticalStackLayout IsVisible="{Binding ShowSourceProfilePicker}"
                                 Spacing="6">
                <Label Text="SOURCE" Style="{StaticResource SettingsSectionHeader}"
                       SemanticProperties.HeadingLevel="Level1" />
                <Picker AutomationId="SourceProfilePicker"
                        Style="{StaticResource SettingsPicker}"
                        ItemsSource="{Binding AvailableProfiles}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        SelectedItem="{Binding SelectedProfile}"
                        SemanticProperties.Description="Source profile" />
            </VerticalStackLayout>

            <!-- Individual pickers (visible only in Custom mode or when no profile manager) -->
            <VerticalStackLayout IsVisible="{Binding IsCustomMode}" Spacing="10">

                <!-- Camera Source -->
                <Label Text="CAMERA SOURCE" Style="{StaticResource SettingsSectionHeader}"
                       SemanticProperties.HeadingLevel="Level1" />
                <Picker AutomationId="CameraSourcePicker"
                        Style="{StaticResource SettingsPicker}"
                        ItemsSource="{Binding CameraProviders}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        SelectedItem="{Binding SelectedCameraProvider}"
                        SemanticProperties.Description="Camera source" />

                <Button Text="Take Picture"
                        Command="{Binding TakePictureCommand}"
                        IsEnabled="{Binding IsTakingPicture, Converter={StaticResource InvertBoolConverter}}"
                        Style="{StaticResource SettingsButton}"
                        AutomationId="TakePictureButton" />

                <Button Text="Record Video"
                        IsVisible="{Binding ShowRecordVideo}"
                        Style="{StaticResource SettingsButton}"
                        AutomationId="RecordVideoButton" />

                <Label Text="{Binding TakePictureStatus}"
                       Style="{StaticResource SettingsStatusText}"
                       AutomationId="TakePictureStatusLabel" />

                <Label Text="{Binding LastPictureLatencyMs, StringFormat='Latency: {0} ms'}"
                       IsVisible="{Binding LastPictureLatencyMs, Converter={StaticResource IsNotNullConverter}}"
                       Style="{StaticResource SettingsStatusText}" />

                <Image Source="{Binding LastPictureImage}"
                       IsVisible="{Binding LastPictureImage, Converter={StaticResource IsNotNullConverter}}"
                       Aspect="AspectFit"
                       HeightRequest="200"
                       AutomationId="LastPictureImage" />

                <!-- Microphone -->
                <Label Text="MICROPHONE" Style="{StaticResource SettingsSectionHeader}"
                       SemanticProperties.HeadingLevel="Level1" />
                <Picker AutomationId="AudioInputPicker"
                        Style="{StaticResource SettingsPicker}"
                        ItemsSource="{Binding AudioInputProviders}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        SelectedItem="{Binding SelectedAudioInputProvider}"
                        SemanticProperties.Description="Microphone" />
                <Label Text="{Binding HeyCyanAudioInputStatus}"
                       IsVisible="{Binding HeyCyanAudioInputStatus, Converter={StaticResource IsNotNullConverter}}"
                       Style="{StaticResource SettingsStatusText}" />

                <Button Text="Test Recording"
                        Command="{Binding TestRecordingCommand}"
                        IsEnabled="{Binding IsTestingRecording, Converter={StaticResource InvertBoolConverter}}"
                        Style="{StaticResource SettingsButton}"
                        AutomationId="TestRecordingButton" />

                <Label Text="{Binding TestRecordingStatus}"
                       IsVisible="{Binding TestRecordingStatus, Converter={StaticResource IsNotNullConverter}}"
                       Style="{StaticResource SettingsStatusText}" />

                <!-- Speaker -->
                <Label Text="SPEAKER" Style="{StaticResource SettingsSectionHeader}"
                       SemanticProperties.HeadingLevel="Level1" />
                <Picker AutomationId="AudioOutputPicker"
                        Style="{StaticResource SettingsPicker}"
                        ItemsSource="{Binding AudioOutputProviders}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        SelectedItem="{Binding SelectedAudioOutputProvider}"
                        SemanticProperties.Description="Speaker" />
                <Label Text="{Binding HeyCyanAudioOutputStatus}"
                       IsVisible="{Binding HeyCyanAudioOutputStatus, Converter={StaticResource IsNotNullConverter}}"
                       Style="{StaticResource SettingsStatusText}" />

                <Button Text="Test Sound"
                        Command="{Binding TestSoundCommand}"
                        Style="{StaticResource SettingsButton}"
                        AutomationId="TestSoundButton" />

            </VerticalStackLayout>

            <!-- Button Mappings (one section per connected button device, expandable) -->
            <CollectionView ItemsSource="{Binding ButtonDeviceMappings}"
                            AutomationId="ButtonDeviceMappingsCollection">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ButtonDeviceMappingsViewModel">
                        <VerticalStackLayout Spacing="6" Margin="0,16,0,0">
                            <!-- Tappable header -->
                            <HorizontalStackLayout Spacing="6" Padding="4,8">
                                <HorizontalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleExpandedCommand}" />
                                </HorizontalStackLayout.GestureRecognizers>
                                <Label FontSize="12" VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="Text" Value="▼" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="False">
                                            <Setter Property="Text" Value="▶" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Label Text="{Binding DeviceName}"
                                       Style="{StaticResource SettingsDeviceHeader}"
                                       SemanticProperties.HeadingLevel="Level1" />
                            </HorizontalStackLayout>
                            <!-- Expandable rows -->
                            <CollectionView ItemsSource="{Binding Rows}"
                                            IsVisible="{Binding IsExpanded}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:GestureRowViewModel">
                                        <Grid ColumnDefinitions="*,2*" Padding="28,4,0,4">
                                            <Label Grid.Column="0" Text="{Binding Label}"
                                                   FontSize="12" VerticalOptions="Center" />
                                            <Picker Grid.Column="1"
                                                    Style="{StaticResource SettingsPicker}"
                                                    ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:ButtonDeviceMappingsViewModel}}, Path=AvailableActions}"
                                                    SelectedItem="{Binding Action, Mode=TwoWay}" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
