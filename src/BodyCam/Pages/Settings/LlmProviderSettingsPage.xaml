<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels.Settings"
             x:Class="BodyCam.Pages.Settings.LlmProviderSettingsPage"
             x:Name="PageRoot"
             x:DataType="vm:LlmProviderDetailViewModel"
             Shell.TabBarIsVisible="False"
             Title="{Binding DisplayName}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14" MaximumWidthRequest="500">

            <Label Text="{Binding Description}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Status" FontAttributes="Bold" />
                    <Label Text="{Binding ActiveStatus}" FontSize="13" />
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        AutomationId="SetActiveProviderButton"
                        Text="Set Active"
                        Command="{Binding SetActiveCommand}"
                        VerticalOptions="Center"
                        Padding="10,6"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryAlt}}"
                        TextColor="White" />
            </Grid>

            <BoxView HeightRequest="1"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

            <Label Text="{Binding ApiKeyTitle}" FontAttributes="Bold" />
            <Label Text="{Binding CredentialNotice}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
            <Entry AutomationId="LlmProviderApiKeyDisplay"
                   Text="{Binding ApiKeyDisplay}"
                   IsPassword="{Binding IsKeyVisible, Converter={StaticResource InvertBoolConverter}}"
                   IsReadOnly="True" />
            <FlexLayout Direction="Row" Wrap="Wrap">
                <Button AutomationId="LlmProviderToggleKeyButton"
                        Text="{Binding KeyToggleText}"
                        Command="{Binding ToggleKeyVisibilityCommand}"
                        Margin="0,0,8,4"
                        Padding="10,6"
                        BackgroundColor="{AppThemeBinding Light={StaticResource ButtonMuted}, Dark={StaticResource ButtonMutedDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                <Button AutomationId="LlmProviderChangeKeyButton"
                        Text="Change"
                        Command="{Binding ChangeApiKeyCommand}"
                        Margin="0,0,8,4"
                        Padding="10,6"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryAlt}}"
                        TextColor="White" />
                <Button AutomationId="LlmProviderClearKeyButton"
                        Text="Clear"
                        Command="{Binding ClearApiKeyCommand}"
                        Margin="0,0,0,4"
                        Padding="10,6"
                        BackgroundColor="{AppThemeBinding Light={StaticResource ButtonMuted}, Dark={StaticResource ButtonMutedDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
            </FlexLayout>

            <BoxView HeightRequest="1"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

            <Label Text="Provider Setup" FontAttributes="Bold" />
            <VerticalStackLayout Spacing="8"
                                 BindableLayout.ItemsSource="{Binding SetupLinks}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProviderSetupLinkViewModel">
                        <Button AutomationId="{Binding AutomationId}"
                                Text="{Binding Label}"
                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenSetupLinkCommand}"
                                CommandParameter="{Binding .}"
                                HorizontalOptions="Fill"
                                Padding="12,8"
                                BackgroundColor="{AppThemeBinding Light={StaticResource ButtonMuted}, Dark={StaticResource ButtonMutedDark}}"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10" IsVisible="{Binding ShowModelPickers}">
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
                <Label Text="Models" FontAttributes="Bold" />

                <Label Text="Realtime Voice" FontSize="13" />
                <Picker AutomationId="LlmRealtimeModelPicker"
                        ItemsSource="{Binding RealtimeModelOptions}"
                        ItemDisplayBinding="{Binding Label}"
                        SelectedItem="{Binding SelectedRealtimeModel}" />

                <Label Text="Text" FontSize="13" />
                <Picker AutomationId="LlmChatModelPicker"
                        ItemsSource="{Binding ChatModelOptions}"
                        ItemDisplayBinding="{Binding Label}"
                        SelectedItem="{Binding SelectedChatModel}" />

                <Label Text="Vision" FontSize="13" />
                <Picker AutomationId="LlmVisionModelPicker"
                        ItemsSource="{Binding VisionModelOptions}"
                        ItemDisplayBinding="{Binding Label}"
                        SelectedItem="{Binding SelectedVisionModel}" />

                <Label Text="STT" FontSize="13" />
                <Picker AutomationId="LlmTranscriptionModelPicker"
                        ItemsSource="{Binding TranscriptionModelOptions}"
                        ItemDisplayBinding="{Binding Label}"
                        SelectedItem="{Binding SelectedTranscriptionModel}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10" IsVisible="{Binding ShowGrokOnlySettings}">
                <Label Text="TTS Voice" FontSize="13" />
                <Entry AutomationId="GrokTtsVoiceEntry"
                       Text="{Binding Voice}"
                       Placeholder="eve" />

                <Label Text="Text to Speech" FontSize="13" />
                <Picker AutomationId="GrokTtsModelPicker"
                        ItemsSource="{Binding TextToSpeechModelOptions}"
                        ItemDisplayBinding="{Binding Label}"
                        SelectedItem="{Binding SelectedTextToSpeechModel}" />

                <Label Text="Image Generation" FontSize="13" />
                <Picker AutomationId="GrokImageModelPicker"
                        ItemsSource="{Binding ImageGenerationModelOptions}"
                        ItemDisplayBinding="{Binding Label}"
                        SelectedItem="{Binding SelectedImageGenerationModel}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10" IsVisible="{Binding ShowAzureDeployments}">
                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
                <Label Text="Azure Deployments" FontAttributes="Bold" />

                <Label Text="Endpoint" FontSize="13" />
                <Entry AutomationId="LlmAzureEndpointEntry"
                       Text="{Binding AzureEndpoint}"
                       Placeholder="https://your-resource.cognitiveservices.azure.com" />

                <Label Text="API Version" FontSize="13" />
                <Entry AutomationId="LlmAzureApiVersionEntry"
                       Text="{Binding AzureApiVersion}"
                       Placeholder="2025-04-01-preview" />

                <Label Text="Realtime Deployment" FontSize="13" />
                <Entry AutomationId="LlmAzureRealtimeDeploymentEntry"
                       Text="{Binding AzureRealtimeDeployment}" />

                <Label Text="Chat Deployment" FontSize="13" />
                <Entry AutomationId="LlmAzureChatDeploymentEntry"
                       Text="{Binding AzureChatDeployment}" />

                <Label Text="Vision Deployment" FontSize="13" />
                <Entry AutomationId="LlmAzureVisionDeploymentEntry"
                       Text="{Binding AzureVisionDeployment}" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

            <Label Text="Capabilities" FontAttributes="Bold" />
            <VerticalStackLayout Spacing="0"
                                 BindableLayout.ItemsSource="{Binding Capabilities}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:CapabilityStatusViewModel">
                        <Grid Padding="0,8" ColumnDefinitions="*,Auto">
                            <Label Text="{Binding Name}" />
                            <Label Grid.Column="1"
                                   Text="{Binding Status}"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Button AutomationId="LlmProviderTestButton"
                    Text="Test Connection"
                    Command="{Binding TestConnectionCommand}"
                    IsEnabled="{Binding IsTesting, Converter={StaticResource InvertBoolConverter}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryAlt}}"
                    TextColor="White" />
            <Label AutomationId="LlmProviderDiagnosticsLabel"
                   Text="{Binding Diagnostics}"
                   FontSize="13" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
