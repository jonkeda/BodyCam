<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels.Settings"
             x:Class="BodyCam.Pages.Settings.CommandDetailSettingsPage"
             x:DataType="vm:CommandDetailViewModel"
             Shell.TabBarIsVisible="False"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12" MaximumWidthRequest="500">
            <Label Text="{Binding Title}"
                   FontSize="Subtitle"
                   FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label AutomationId="CommandIdLabel"
                   Text="{Binding CommandId}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}" />
            <Label AutomationId="CommandToolLabel"
                   Text="{Binding ToolText}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}" />

            <Label Text="Settings"
                   FontSize="Subtitle"
                   FontAttributes="Bold"
                   Margin="0,12,0,0"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label Text="Touch behavior"
                   FontSize="Small"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                   IsVisible="{Binding HasLookSettings}" />
            <Picker AutomationId="TouchCommandModePicker"
                    ItemsSource="{Binding TouchModeOptions}"
                    SelectedItem="{Binding SelectedTouchCommandMode}"
                    IsVisible="{Binding HasLookSettings}"
                    SemanticProperties.Description="Touch command behavior" />

            <Label Text="Default response"
                   FontSize="Small"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                   IsVisible="{Binding HasLookSettings}" />
            <Picker AutomationId="LookDefaultResponsePicker"
                    ItemsSource="{Binding LookDetailOptions}"
                    SelectedItem="{Binding SelectedLookDetailLevel}"
                    IsVisible="{Binding HasLookSettings}"
                    SemanticProperties.Description="Default Look response" />

            <Label Text="Default response"
                   FontSize="Small"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                   IsVisible="{Binding HasReadSettings}" />
            <Picker AutomationId="ReadDefaultResponsePicker"
                    ItemsSource="{Binding ReadDetailOptions}"
                    SelectedItem="{Binding SelectedReadDetailLevel}"
                    IsVisible="{Binding HasReadSettings}"
                    SemanticProperties.Description="Default Read response" />

            <Grid ColumnDefinitions="*,Auto"
                  IsVisible="{Binding HasScanSettings}">
                <Label Text="Confirm external actions"
                       VerticalOptions="Center" />
                <Switch AutomationId="ConfirmExternalScanActionsSwitch"
                        Grid.Column="1"
                        IsToggled="{Binding ConfirmExternalScanActions}"
                        SemanticProperties.Description="Confirm external scan actions" />
            </Grid>

            <Label Text="Prompts"
                   FontSize="Subtitle"
                   FontAttributes="Bold"
                   Margin="0,12,0,0"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label AutomationId="NoCommandPromptsLabel"
                   Text="This command does not use a model prompt."
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}"
                   IsVisible="{Binding HasNoPromptDefinitions}" />

            <CollectionView AutomationId="CommandPromptsList"
                            ItemsSource="{Binding PromptDefinitions}"
                            SelectionMode="None"
                            IsVisible="{Binding HasPromptDefinitions}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:CommandPromptPreview">
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{AppThemeBinding Light={StaticResource BorderDefault}, Dark={StaticResource BorderDefaultDark}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardSurface}, Dark={StaticResource CardSurfaceDark}}"
                                Padding="12"
                                Margin="0,0,0,10"
                                AutomationId="{Binding AutomationId}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding DisplayName}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                <Label Text="Text"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                                <Label Text="{Binding Text}"
                                       FontSize="13"
                                       LineBreakMode="WordWrap"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                <Label Text="Prompt"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                                <Label Text="{Binding Prompt}"
                                       FontSize="12"
                                       LineBreakMode="WordWrap"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
