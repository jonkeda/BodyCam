<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels.Settings"
             x:Class="BodyCam.Pages.Settings.AddLlmProviderPage"
             x:DataType="vm:AddLlmProviderViewModel"
             Shell.TabBarIsVisible="False"
             Title="Add LLM Provider">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="8" MaximumWidthRequest="500"
                             BindableLayout.ItemsSource="{Binding ProviderChoices}">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="vm:AddLlmProviderChoiceViewModel">
                    <Grid Padding="0,12"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="4">
                        <Label Text="{Binding DisplayName}"
                               FontAttributes="Bold"
                               FontSize="16" />
                        <Label Grid.Row="1"
                               Text="{Binding Detail}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                        <Button Grid.RowSpan="2"
                                AutomationId="{Binding AutomationId}"
                                Clicked="OnProviderTapped"
                                BackgroundColor="Transparent"
                                Opacity="0.01" />
                    </Grid>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
