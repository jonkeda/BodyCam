<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels"
             x:Class="BodyCam.Pages.Main.Views.StatusBarView"
             x:DataType="vm:MainViewModel">

    <Grid ColumnDefinitions="Auto,Auto,*,Auto" Padding="12,8"
          BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">

        <Border StrokeShape="RoundRectangle 16"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                Padding="2"
                HorizontalOptions="Start"
                HeightRequest="36">
            <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="0">
                <Button AutomationId="OffButton"
                        Command="{Binding SetStateCommand}"
                        CommandParameter="Off"
                        BackgroundColor="{Binding OffSegmentColor}"
                        ImageSource="{Binding OffIcon}"
                        CornerRadius="14"
                        HeightRequest="32" MinimumWidthRequest="44"
                        Padding="6,0" />
                <Button Grid.Column="1" AutomationId="OnButton"
                        Command="{Binding SetStateCommand}"
                        CommandParameter="On"
                        BackgroundColor="{Binding OnSegmentColor}"
                        ImageSource="{Binding OnIcon}"
                        CornerRadius="14"
                        HeightRequest="32" MinimumWidthRequest="44"
                        Padding="6,0" />
                <Button Grid.Column="2" AutomationId="ListeningButton"
                        Command="{Binding SetStateCommand}"
                        CommandParameter="Listening"
                        BackgroundColor="{Binding ListeningSegmentColor}"
                        ImageSource="{Binding ListeningIcon}"
                        CornerRadius="14"
                        HeightRequest="32" MinimumWidthRequest="44"
                        Padding="6,0" />
            </Grid>
        </Border>

        <Label Grid.Column="1" AutomationId="StateLabel"
               Text="{Binding SelectedStateText}"
               FontSize="13" FontAttributes="Bold"
               VerticalOptions="Center" Margin="8,0,0,0"
               TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}" />

        <Button Grid.Column="3" AutomationId="ClearButton"
                Command="{Binding ClearCommand}"
                WidthRequest="40" HeightRequest="32"
                Padding="0"
                BackgroundColor="Transparent">
            <Button.ImageSource>
                <FileImageSource File="trash.png" />
            </Button.ImageSource>
        </Button>
    </Grid>
</ContentView>
