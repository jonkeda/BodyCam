<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels"
             x:Class="BodyCam.Pages.Main.Views.StatusBarView"
             x:DataType="vm:MainViewModel">

    <Grid Padding="12,8"
          ColumnDefinitions="Auto,Auto,*,Auto,Auto"
          ColumnSpacing="8"
          BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">

        <Border StrokeShape="RoundRectangle 16"
                Stroke="{AppThemeBinding Light={StaticResource BorderDefault}, Dark={StaticResource BorderDefaultDark}}"
                Padding="2"
                HorizontalOptions="Start"
                MinimumHeightRequest="44"
                SemanticProperties.Description="Mode">
            <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="0">
                <Button AutomationId="OffButton"
                        Text="Sleep"
                        Command="{Binding SetStateCommand}"
                        CommandParameter="Sleep"
                        BackgroundColor="{Binding OffSegmentColor}"
                        TextColor="{Binding OffSegmentTextColor}"
                        CornerRadius="14"
                        HeightRequest="44" MinimumWidthRequest="56"
                        Padding="10,0"
                        SemanticProperties.Description="{Binding SleepChipText}"
                        SemanticProperties.Hint="Sets BodyCam to sleep mode" />
                <Button Grid.Column="1" AutomationId="OnButton"
                        Text="Listen"
                        Command="{Binding SetStateCommand}"
                        CommandParameter="Listen"
                        BackgroundColor="{Binding OnSegmentColor}"
                        TextColor="{Binding OnSegmentTextColor}"
                        CornerRadius="14"
                        HeightRequest="44" MinimumWidthRequest="56"
                        Padding="10,0"
                        SemanticProperties.Description="{Binding ListenChipText}"
                        SemanticProperties.Hint="Listens for the wake word" />
                <Button Grid.Column="2" AutomationId="ListeningButton"
                        Text="Active"
                        Command="{Binding SetStateCommand}"
                        CommandParameter="Active"
                        BackgroundColor="{Binding ListeningSegmentColor}"
                        TextColor="{Binding ListeningSegmentTextColor}"
                        CornerRadius="14"
                        HeightRequest="44" MinimumWidthRequest="56"
                        Padding="10,0"
                        SemanticProperties.Description="{Binding ActiveChipText}"
                        SemanticProperties.Hint="Starts the active session" />
            </Grid>
        </Border>

        <Border Grid.Column="1"
                StrokeShape="RoundRectangle 16"
                Stroke="{AppThemeBinding Light={StaticResource BorderDefault}, Dark={StaticResource BorderDefaultDark}}"
                Padding="2"
                HorizontalOptions="Start"
                MinimumHeightRequest="44"
                SemanticProperties.Description="Output mode">
            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="0">
                <Button AutomationId="SpeakButton"
                        Text="Speak"
                        Command="{Binding SetOutputModeCommand}"
                        CommandParameter="Speak"
                        BackgroundColor="{Binding SpeakSegmentColor}"
                        TextColor="{Binding SpeakSegmentTextColor}"
                        CornerRadius="14"
                        HeightRequest="44" MinimumWidthRequest="56"
                        Padding="10,0"
                        SemanticProperties.Description="{Binding SpeakChipText}"
                        SemanticProperties.Hint="Plays responses aloud and shows them in the transcript" />
                <Button Grid.Column="1"
                        AutomationId="SilentButton"
                        Text="Silent"
                        Command="{Binding SetOutputModeCommand}"
                        CommandParameter="Silent"
                        BackgroundColor="{Binding SilentSegmentColor}"
                        TextColor="{Binding SilentSegmentTextColor}"
                        CornerRadius="14"
                        HeightRequest="44" MinimumWidthRequest="56"
                        Padding="10,0"
                        SemanticProperties.Description="{Binding SilentChipText}"
                        SemanticProperties.Hint="Shows responses only in the transcript" />
            </Grid>
        </Border>

        <Border Grid.Column="3"
                IsVisible="{Binding GlassesConnected}"
                StrokeShape="RoundRectangle 14"
                Stroke="{AppThemeBinding Light={StaticResource BorderDefault}, Dark={StaticResource BorderDefaultDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource MutedSurface}, Dark={StaticResource CardSurfaceDark}}"
                Padding="10,0"
                MinimumHeightRequest="44"
                VerticalOptions="Center"
                SemanticProperties.Description="Glasses status">
            <HorizontalStackLayout Spacing="4"
                                   VerticalOptions="Center">
                <Label Text="{Binding GlassesBatteryPct, StringFormat='Glasses {0}%'}"
                       FontSize="12"
                       VerticalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                <Label Text="Charging"
                       FontSize="12"
                       VerticalTextAlignment="Center"
                       IsVisible="{Binding GlassesCharging}"
                       TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}" />
            </HorizontalStackLayout>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding NavigateToGlassesCommand}" />
            </Border.GestureRecognizers>
        </Border>

        <Button Grid.Column="4"
                AutomationId="SettingsButton"
                Text="&#x2699;"
                Command="{Binding NavigateToSettingsCommand}"
                HeightRequest="44"
                WidthRequest="44"
                Padding="0"
                FontSize="22"
                CornerRadius="22"
                BackgroundColor="Transparent"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                SemanticProperties.Description="Settings"
                SemanticProperties.Hint="Opens settings" />
    </Grid>
</ContentView>
