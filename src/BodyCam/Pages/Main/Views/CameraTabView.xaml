<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="BodyCam.Pages.Main.Views.CameraTabView"
             x:DataType="vm:MainViewModel">

    <Grid x:Name="CameraPreviewPanel"
          AutomationId="CameraPreviewPanel"
          IsVisible="{Binding ShowCameraActionsSection}"
          Padding="8,0,8,8"
          SemanticProperties.Description="Camera preview and camera actions">
        <Border StrokeShape="RoundRectangle 8"
                Stroke="{AppThemeBinding Light={StaticResource BorderDefault}, Dark={StaticResource BorderDefaultDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardSurface}, Dark={StaticResource CardSurfaceDark}}"
                Padding="8">
            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="8">
                <toolkit:CameraView x:Name="CameraPreview"
                                    AutomationId="CameraPreview"
                                    IsVisible="{Binding ShowInlineCameraPreview}"
                                    HeightRequest="220"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"
                                    SemanticProperties.Description="Camera preview" />

                <FlexLayout Grid.Row="1"
                            AutomationId="CameraActionRail"
                            IsVisible="{Binding ShowCameraActionRail}"
                            BindableLayout.ItemsSource="{Binding CameraActions}"
                            Direction="Row"
                            Wrap="Wrap"
                            JustifyContent="Center"
                            AlignItems="Stretch">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:CameraActionItemViewModel">
                            <Button AutomationId="{Binding AutomationId}"
                                    Text="{Binding Label}"
                                    Command="{Binding ActivateCommand}"
                                    HeightRequest="56"
                                    MinimumWidthRequest="112"
                                    Margin="4"
                                    Padding="12,0"
                                    CornerRadius="8"
                                    FontSize="16"
                                    BackgroundColor="{Binding ButtonColor}"
                                    TextColor="{Binding TextColor}"
                                    SemanticProperties.Description="{Binding SemanticDescription}"
                                    SemanticProperties.Hint="{Binding SemanticHint}" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <FlexLayout Grid.Row="2"
                            AutomationId="CameraActionVariantRail"
                            IsVisible="{Binding HasActiveCameraActionVariants}"
                            BindableLayout.ItemsSource="{Binding ActiveCameraActionVariants}"
                            Direction="Row"
                            Wrap="Wrap"
                            JustifyContent="Center"
                            AlignItems="Stretch">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:CameraActionVariantViewModel">
                            <Button AutomationId="{Binding AutomationId}"
                                    Text="{Binding Label}"
                                    Command="{Binding ExecuteCommand}"
                                    HeightRequest="56"
                                    MinimumWidthRequest="112"
                                    Margin="4"
                                    Padding="12,0"
                                    CornerRadius="8"
                                    FontSize="16"
                                    BackgroundColor="{Binding ButtonColor}"
                                    TextColor="{Binding TextColor}"
                                    SemanticProperties.Description="{Binding SemanticDescription}"
                                    SemanticProperties.Hint="{Binding SemanticHint}" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

            </Grid>
        </Border>

        <!-- Snapshot overlay -->
        <Grid IsVisible="{Binding ShowSnapshot}"
              BackgroundColor="{StaticResource Overlay}"
              Padding="16">
            <Border StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardSurface}, Dark={StaticResource CardSurfaceDark}}"
                    Padding="8"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="400">
                <VerticalStackLayout Spacing="8">
                    <Image AutomationId="SnapshotImage"
                           Source="{Binding SnapshotImage}"
                           HeightRequest="300"
                           Aspect="AspectFit" />
                    <Label AutomationId="SnapshotCaption"
                           Text="{Binding SnapshotCaption}"
                           FontSize="14"
                           HorizontalTextAlignment="Center" />
                    <Button x:Name="DismissSnapshotButton" AutomationId="DismissSnapshotButton"
                            Text="Dismiss"
                            Command="{Binding DismissSnapshotCommand}"
                            HorizontalOptions="Center"
                            BackgroundColor="{AppThemeBinding Light={StaticResource ButtonMuted}, Dark={StaticResource ButtonMutedDark}}" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentView>
