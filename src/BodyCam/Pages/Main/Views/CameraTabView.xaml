<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="BodyCam.Pages.Main.Views.CameraTabView"
             x:DataType="vm:MainViewModel">

    <Grid x:Name="CameraPreviewPanel"
          AutomationId="CameraPreviewPanel"
          IsVisible="{Binding ShowInlineCameraPreview}"
          Padding="8,0,8,8"
          SemanticProperties.Description="Camera preview">
        <Border StrokeShape="RoundRectangle 8"
                Stroke="{AppThemeBinding Light={StaticResource BorderDefault}, Dark={StaticResource BorderDefaultDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardSurface}, Dark={StaticResource CardSurfaceDark}}"
                Padding="8">
            <Grid RowDefinitions="220,Auto"
                  RowSpacing="8">
                <toolkit:CameraView x:Name="CameraPreview"
                                    AutomationId="CameraPreview"
                                    HeightRequest="220"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"
                                    SemanticProperties.Description="Camera preview" />

                <Button Grid.Row="1"
                        AutomationId="CaptureFrameButton"
                        Text="●"
                        Command="{Binding PhotoCommand}"
                        WidthRequest="56"
                        HeightRequest="56"
                        CornerRadius="28"
                        FontSize="28"
                        Padding="0"
                        HorizontalOptions="Center"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                        SemanticProperties.Description="Capture frame"
                        SemanticProperties.Hint="Captures a camera frame and adds it to the transcript" />
            </Grid>
        </Border>

        <!-- Snapshot overlay -->
        <Grid IsVisible="{Binding ShowSnapshot}"
              BackgroundColor="{StaticResource Overlay}"
              Padding="16">
            <Border StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardSurface}, Dark={StaticResource CardSurfaceDark}}"
                    Padding="8"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="400">
                <VerticalStackLayout Spacing="8">
                    <Image AutomationId="SnapshotImage"
                           Source="{Binding SnapshotImage}"
                           HeightRequest="300"
                           Aspect="AspectFit" />
                    <Label AutomationId="SnapshotCaption"
                           Text="{Binding SnapshotCaption}"
                           FontSize="14"
                           HorizontalTextAlignment="Center" />
                    <Button x:Name="DismissSnapshotButton" AutomationId="DismissSnapshotButton"
                            Text="Dismiss"
                            Command="{Binding DismissSnapshotCommand}"
                            HorizontalOptions="Center"
                            BackgroundColor="{AppThemeBinding Light={StaticResource ButtonMuted}, Dark={StaticResource ButtonMutedDark}}" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentView>
