<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels"
             x:Class="BodyCam.Pages.Main.Views.QuickActionsView"
             x:DataType="vm:MainViewModel">

    <VerticalStackLayout Padding="12"
                         BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
        <Button AutomationId="ActionsDrawerButton"
                Text="{Binding ActionsDrawerButtonText}"
                Command="{Binding ToggleActionsDrawerCommand}"
                HeightRequest="44"
                HorizontalOptions="Fill"
                CornerRadius="8"
                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                SemanticProperties.Description="{Binding ActionsDrawerSemanticDescription}"
                SemanticProperties.Hint="Shows or hides available actions" />
    </VerticalStackLayout>
</ContentView>
