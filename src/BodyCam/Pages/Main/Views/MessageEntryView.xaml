<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels"
             x:Class="BodyCam.Pages.Main.Views.MessageEntryView"
             x:DataType="vm:MainViewModel">

    <Grid Padding="8,0,8,8"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="8"
          BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
        <Border StrokeShape="RoundRectangle 8"
                Stroke="{AppThemeBinding Light={StaticResource BorderDefault}, Dark={StaticResource BorderDefaultDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardSurface}, Dark={StaticResource CardSurfaceDark}}"
                Padding="8,0"
                MinimumHeightRequest="48">
            <Entry AutomationId="MessageEntry"
                   Text="{Binding MessageText}"
                   ReturnCommand="{Binding SendMessageCommand}"
                   ReturnType="Send"
                   Placeholder="Message"
                   ClearButtonVisibility="WhileEditing"
                   VerticalOptions="Center"
                   SemanticProperties.Description="Message"
                   SemanticProperties.Hint="Enter a typed message" />
        </Border>

        <Button Grid.Column="1"
                AutomationId="SendMessageButton"
                Text="Send"
                Command="{Binding SendMessageCommand}"
                HeightRequest="48"
                MinimumWidthRequest="64"
                CornerRadius="8"
                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                SemanticProperties.Description="Send message"
                SemanticProperties.Hint="Sends the typed message" />
    </Grid>
</ContentView>
