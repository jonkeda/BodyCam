<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BodyCam.Models"
             x:Class="BodyCam.Pages.Main.Views.TranscriptView">

    <Frame BorderColor="{AppThemeBinding Light={StaticResource BorderDefault}, Dark={StaticResource BorderDefaultDark}}"
           Padding="8"
           CornerRadius="4"
           Margin="8"
           SemanticProperties.Description="Transcript">
        <CollectionView x:Name="TranscriptList"
                        AutomationId="TranscriptList"
                        ItemsSource="{Binding Entries}"
                        SemanticProperties.Description="Conversation transcript">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TranscriptEntry">
                    <VerticalStackLayout Padding="4,2"
                                         SemanticProperties.Description="{Binding AccessibleText}">
                        <Label AutomationId="{Binding AutomationId}"
                               IsVisible="{Binding ShowText}"
                               FormattedText="{Binding FormattedText}"
                               FontSize="14"
                               FontFamily="OpenSansRegular"
                               SemanticProperties.Description="{Binding AccessibleText}"
                               TextColor="{Binding RoleColor}" />
                        <Image Source="{Binding Image}"
                               IsVisible="{Binding HasImage}"
                               HeightRequest="200"
                               Aspect="AspectFit"
                               SemanticProperties.Description="{Binding ImageCaption}"
                               Margin="0,4" />
                        <Label AutomationId="TranscriptImageCaptionLabel"
                               Text="{Binding ImageCaption}"
                               IsVisible="{Binding HasImage}"
                               FontSize="12"
                               TextColor="Gray"
                               FontAttributes="Italic" />
                        <!-- Inline action buttons -->
                        <HorizontalStackLayout IsVisible="{Binding HasActions}"
                                               BindableLayout.ItemsSource="{Binding Actions}"
                                               Spacing="8" Margin="0,4,0,0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:ContentAction">
                                    <Button Text="{Binding Label}"
                                            Command="{Binding Command}"
                                            FontSize="12"
                                            HeightRequest="44"
                                            MinimumWidthRequest="44"
                                            Padding="8,0"
                                            CornerRadius="4"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource InfoSurface}, Dark={StaticResource InfoSurfaceDark}}"
                                            TextColor="{AppThemeBinding Light={StaticResource InfoText}, Dark={StaticResource InfoTextDark}}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Frame>

</ContentView>
