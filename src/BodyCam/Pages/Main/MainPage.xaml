<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels"
             xmlns:converters="clr-namespace:BodyCam.Converters"
             xmlns:views="clr-namespace:BodyCam.Pages.Main.Views"
             x:Class="BodyCam.Pages.Main.MainPage"
             x:DataType="vm:MainViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <converters:InvertBoolConverter x:Key="InvertBool" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">

        <!-- Row 0: Status bar -->
        <views:StatusBarView Grid.Row="0" />

        <!-- Row 1: Transcript owns the main screen area. -->
        <views:TranscriptView Grid.Row="1" x:Name="TranscriptPanel" />

        <!-- Row 2: Typed message entry stays available below the transcript. -->
        <views:MessageEntryView Grid.Row="2" />

        <!-- Row 3: Inline camera preview; hidden until Look, Read, or Scan needs it. -->
        <views:CameraTabView Grid.Row="3" x:Name="CameraPanel" />

        <!-- Row 4: Bottom actions button. -->
        <views:QuickActionsView Grid.Row="4" />

        <!-- Action list overlays the page above the bottom Actions button. -->
        <views:ActionsDrawerView Grid.Row="1" Grid.RowSpan="3" />

        <!-- Scan result overlay floats over the first page content. -->
        <views:ScanResultOverlay Grid.Row="1" Grid.RowSpan="4" />

        <!-- Debug overlay remains nonmodal and anchored at the bottom. -->
        <views:DebugOverlayView Grid.Row="1" Grid.RowSpan="4" />
    </Grid>
</ContentPage>
