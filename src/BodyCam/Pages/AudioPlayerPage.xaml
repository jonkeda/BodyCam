<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BodyCam.Pages.AudioPlayerPage"
             Title="Audio Player"
             Shell.TabBarIsVisible="False">

    <VerticalStackLayout Padding="16" Spacing="12" VerticalOptions="Center">
        <Label x:Name="FileNameLabel"
               FontSize="20"
               HorizontalOptions="Center"
               AutomationId="FileNameLabel" />

        <Label Text="🎙"
               FontSize="64"
               HorizontalOptions="Center"
               Margin="0,24" />

        <Button x:Name="PlayButton"
                Text="Play with System Player"
                Clicked="OnPlayClicked"
                HorizontalOptions="Center"
                AutomationId="PlayButton" />
    </VerticalStackLayout>
</ContentPage>
