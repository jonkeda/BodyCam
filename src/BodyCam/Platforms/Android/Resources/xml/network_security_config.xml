<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
	<!--
		The glasses expose local HTTP endpoints such as
		http://192.168.49.x/files/media.config over Wi-Fi Direct. Android network
		security config does not support a subnet wildcard for IP addresses, so a
		base config is the practical option for this local-device transfer path.
	-->
	<base-config cleartextTrafficPermitted="true">
		<trust-anchors>
			<certificates src="system" />
		</trust-anchors>
	</base-config>
</network-security-config>
