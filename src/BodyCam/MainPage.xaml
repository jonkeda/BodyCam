<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels"
             xmlns:models="clr-namespace:BodyCam.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="BodyCam.MainPage"
             x:DataType="vm:MainViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*,Auto,200" Padding="16" RowSpacing="12">

        <!-- Header -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12" VerticalOptions="Center">
            <Button
                Text="{Binding ToggleButtonText}"
                Command="{Binding ToggleCommand}"
                WidthRequest="120"
                BackgroundColor="{AppThemeBinding Light=#512BD4, Dark=#7C4DFF}"
                TextColor="White" />
            <Button
                Text="Clear"
                Command="{Binding ClearCommand}"
                WidthRequest="80"
                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}" />
            <Label
                Text="{Binding StatusText}"
                FontSize="16"
                VerticalOptions="Center"
                TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />
            <Label
                Text="{Binding VisionStatus}"
                FontSize="12"
                VerticalOptions="Center"
                TextColor="{AppThemeBinding Light=#999, Dark=#666}"
                IsVisible="{Binding IsRunning}" />
        </HorizontalStackLayout>

        <!-- Transcript with camera preview overlay -->
        <Grid Grid.Row="1">
            <Frame BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}" Padding="8" CornerRadius="4">
                <CollectionView
                    x:Name="TranscriptList"
                    ItemsSource="{Binding Entries}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TranscriptEntry">
                            <VerticalStackLayout Padding="4,2">
                                <Label Text="{Binding DisplayText}"
                                       FontSize="14"
                                       FontFamily="OpenSansRegular" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Frame>

            <Border StrokeShape="RoundRectangle 4"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#555}"
                    BackgroundColor="Black"
                    WidthRequest="160" HeightRequest="120"
                    HorizontalOptions="End" VerticalOptions="Start"
                    Margin="8"
                    IsVisible="{Binding IsRunning}">
                <toolkit:CameraView x:Name="CameraPreview" />
            </Border>
        </Grid>

        <!-- Section label -->
        <Label Grid.Row="2" Text="Debug Console" FontSize="12" TextColor="Gray"
               IsVisible="{Binding DebugVisible}" />

        <!-- Debug log -->
        <Frame Grid.Row="3" BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}" Padding="8" CornerRadius="4"
               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A1A}"
               IsVisible="{Binding DebugVisible}">
            <ScrollView x:Name="DebugScroll">
                <Label
                    Text="{Binding DebugLog}"
                    FontSize="11"
                    FontFamily="OpenSansRegular"
                    TextColor="Gray" />
            </ScrollView>
        </Frame>

    </Grid>

</ContentPage>
