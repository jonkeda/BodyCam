<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels"
             xmlns:models="clr-namespace:BodyCam.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:converters="clr-namespace:BodyCam.Converters"
             x:Class="BodyCam.MainPage"
             x:DataType="vm:MainViewModel"
             Shell.TabBarIsVisible="False"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <converters:InvertBoolConverter x:Key="InvertBool" />
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="MinimumHeightRequest" Value="44" />
            <Setter Property="FontSize" Value="Body" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="BackgroundColor"
                    Value="{AppThemeBinding Light=#EEEEEE, Dark=#2A2A2A}" />
            <Setter Property="TextColor"
                    Value="{AppThemeBinding Light=#333333, Dark=#E0E0E0}" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="Focused">
                            <VisualState.Setters>
                                <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                <Setter Property="BorderWidth" Value="2" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="0.5" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Row 0: Status bar -->
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="12,8"
              BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">

            <!-- State dot -->
            <Ellipse AutomationId="StatusDot"
                     WidthRequest="12" HeightRequest="12"
                     Fill="{Binding StateColor}"
                     VerticalOptions="Center"
                     SemanticProperties.Description="{Binding StateDescription}" />

            <!-- State pill (segmented control) -->
            <Border Grid.Column="1" StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    Padding="2" Margin="8,0"
                    HorizontalOptions="Start"
                    MinimumHeightRequest="36">
                <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="0">
                    <Button AutomationId="SleepButton"
                            Text="😴" TabIndex="10"
                            Command="{Binding SetStateCommand}"
                            CommandParameter="Sleep"
                            BackgroundColor="{Binding SleepSegmentColor}"
                            TextColor="{Binding SleepSegmentTextColor}"
                            CornerRadius="14"
                            MinimumHeightRequest="32" MinimumWidthRequest="56"
                            FontSize="Body" Padding="8,0"
                            VerticalOptions="Center"
                            SemanticProperties.Description="Sleep mode"
                            SemanticProperties.Hint="Puts the assistant to sleep">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="Focused">
                                        <VisualState.Setters>
                                            <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                            <Setter Property="BorderWidth" Value="2" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                    </Button>
                    <Button Grid.Column="1" AutomationId="ListenButton"
                            Text="👂" TabIndex="11"
                            Command="{Binding SetStateCommand}"
                            CommandParameter="Listen"
                            BackgroundColor="{Binding ListenSegmentColor}"
                            TextColor="{Binding ListenSegmentTextColor}"
                            CornerRadius="14"
                            MinimumHeightRequest="32" MinimumWidthRequest="56"
                            FontSize="Body" Padding="8,0"
                            VerticalOptions="Center"
                            SemanticProperties.Description="Listen mode"
                            SemanticProperties.Hint="Activates wake word listening">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="Focused">
                                        <VisualState.Setters>
                                            <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                            <Setter Property="BorderWidth" Value="2" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                    </Button>
                    <Button Grid.Column="2" AutomationId="ActiveButton"
                            Text="💬" TabIndex="12"
                            Command="{Binding SetStateCommand}"
                            CommandParameter="Active"
                            BackgroundColor="{Binding ActiveSegmentColor}"
                            TextColor="{Binding ActiveSegmentTextColor}"
                            CornerRadius="14"
                            MinimumHeightRequest="32" MinimumWidthRequest="56"
                            FontSize="Body" Padding="8,0"
                            VerticalOptions="Center"
                            SemanticProperties.Description="Active session"
                            SemanticProperties.Hint="Starts an active conversation">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="Focused">
                                        <VisualState.Setters>
                                            <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                            <Setter Property="BorderWidth" Value="2" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                    </Button>
                </Grid>
            </Border>

            <!-- Debug toggle -->
            <Button Grid.Column="2" AutomationId="DebugToggleButton"
                    Text="🐛" TabIndex="13"
                    Command="{Binding ToggleDebugCommand}"
                    WidthRequest="40" MinimumHeightRequest="32"
                    FontSize="Subtitle" Padding="0"
                    BackgroundColor="Transparent"
                    SemanticProperties.Description="Toggle debug console"
                    SemanticProperties.Hint="Shows or hides the debug log" />

            <!-- Clear button -->
            <Button Grid.Column="3" AutomationId="ClearButton"
                    Text="Clear" TabIndex="14"
                    Command="{Binding ClearCommand}"
                    WidthRequest="60" MinimumHeightRequest="32"
                    FontSize="Caption"
                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                    TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}"
                    SemanticProperties.Description="Clear transcript"
                    SemanticProperties.Hint="Removes all transcript entries" />
        </Grid>

        <!-- Row 1: Content area (transcript OR camera) -->
        <Grid Grid.Row="1">

            <!-- Transcript tab -->
            <Frame IsVisible="{Binding ShowTranscriptTab}"
                   BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}" Padding="8" CornerRadius="4">
                <CollectionView x:Name="TranscriptList"
                                AutomationId="TranscriptList"
                                ItemsSource="{Binding Entries}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TranscriptEntry">
                            <VerticalStackLayout Padding="4,2" Opacity="0" TranslationY="20"
                                                 Loaded="EntryItem_Loaded"
                                                 SemanticProperties.Description="{Binding AccessibleText}">

                                <!-- Thinking dots — visible only while IsThinking -->
                                <HorizontalStackLayout IsVisible="{Binding IsThinking}"
                                                       Spacing="6" Padding="4,8"
                                                       Loaded="ThinkingDots_Loaded"
                                                       SemanticProperties.Description="Thinking...">
                                    <Ellipse WidthRequest="8" HeightRequest="8"
                                             Fill="{Binding RoleColor}" Opacity="0.3" />
                                    <Ellipse WidthRequest="8" HeightRequest="8"
                                             Fill="{Binding RoleColor}" Opacity="0.3" />
                                    <Ellipse WidthRequest="8" HeightRequest="8"
                                             Fill="{Binding RoleColor}" Opacity="0.3" />
                                </HorizontalStackLayout>

                                <!-- Normal content — hidden while thinking -->
                                <Label Text="{Binding DisplayText}"
                                       IsVisible="{Binding IsThinking, Converter={StaticResource InvertBool}}"
                                       FontSize="Body"
                                       FontFamily="OpenSansRegular"
                                       TextColor="{Binding RoleColor}" />
                                <Image Source="{Binding Image}"
                                       IsVisible="{Binding HasImage}"
                                       HeightRequest="200"
                                       Aspect="AspectFit"
                                       Margin="0,4"
                                       SemanticProperties.Description="{Binding ImageCaption}" />
                                <Label Text="{Binding ImageCaption}"
                                       IsVisible="{Binding HasImage}"
                                       FontSize="Caption"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                                       FontAttributes="Italic" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Frame>

            <!-- Camera tab -->
            <Grid IsVisible="{Binding ShowCameraTab}">
                <Label AutomationId="CameraPlaceholder" 
                       Text="Camera initializing..."
                       HorizontalOptions="Center" VerticalOptions="Center"
                       FontSize="Body"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                       SemanticProperties.Description="Camera is initializing" />
                <toolkit:CameraView x:Name="CameraPreview" AutomationId="CameraPreview" />

                <!-- Snapshot overlay -->
                <Grid IsVisible="{Binding ShowSnapshot}"
                      BackgroundColor="#80000000"
                      Padding="16">
                    <Border StrokeShape="RoundRectangle 8"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                            Padding="8"
                            VerticalOptions="Center"
                            HorizontalOptions="Center"
                            MaximumWidthRequest="400">
                        <VerticalStackLayout Spacing="8">
                            <Image AutomationId="SnapshotImage"
                                   Source="{Binding SnapshotImage}"
                                   HeightRequest="300"
                                   Aspect="AspectFit"
                                   SemanticProperties.Description="{Binding SnapshotCaption}" />
                            <Label AutomationId="SnapshotCaption"
                                   Text="{Binding SnapshotCaption}"
                                   FontSize="Body"
                                   HorizontalTextAlignment="Center" />
                            <Button AutomationId="DismissSnapshotButton"
                                    x:Name="DismissSnapshotButton"
                                    Text="Dismiss" TabIndex="40"
                                    Command="{Binding DismissSnapshotCommand}"
                                    HorizontalOptions="Center"
                                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                                    SemanticProperties.Hint="Closes the snapshot overlay" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>

            <!-- Debug overlay -->
            <Grid IsVisible="{Binding DebugVisible}"
                  VerticalOptions="End"
                  MaximumHeightRequest="250"
                  BackgroundColor="{AppThemeBinding Light=#F5F5F5CC, Dark=#1A1A1ACC}">
                <Frame Padding="8" CornerRadius="8">
                    <ScrollView x:Name="DebugScroll" AutomationId="DebugScroll">
                        <Label AutomationId="DebugLabel"
                               Text="{Binding DebugLog}"
                               FontSize="Micro"
                               FontFamily="OpenSansRegular"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                               SemanticProperties.Description="Debug log output" />
                    </ScrollView>
                </Frame>
            </Grid>
        </Grid>

        <!-- Row 2: Tab selector -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" MinimumHeightRequest="40"
              BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#222222}">
            <Button AutomationId="TranscriptTabButton"
                    Text="📝 Transcript" TabIndex="20"
                    Command="{Binding SwitchToTranscriptCommand}"
                    BackgroundColor="{Binding TranscriptTabBackground}"
                    TextColor="{Binding TranscriptTabTextColor}"
                    CornerRadius="8"
                    FontSize="Body"
                    SemanticProperties.Description="Transcript tab"
                    SemanticProperties.Hint="Shows the conversation transcript" />
            <Button Grid.Column="1" AutomationId="CameraTabButton"
                    Text="📷 Camera" TabIndex="21"
                    Command="{Binding SwitchToCameraCommand}"
                    BackgroundColor="{Binding CameraTabBackground}"
                    TextColor="{Binding CameraTabTextColor}"
                    CornerRadius="8"
                    FontSize="Body"
                    SemanticProperties.Description="Camera tab"
                    SemanticProperties.Hint="Shows the live camera feed" />
        </Grid>

        <!-- Row 3: Quick action bar -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto"
              ColumnSpacing="4" RowSpacing="4" Padding="8">
            <Button AutomationId="LookButton"
                    Text="👁 Look" TabIndex="30"
                    Command="{Binding LookCommand}"
                    Style="{StaticResource ActionButton}"
                    SemanticProperties.Description="Look"
                    SemanticProperties.Hint="Describes what the camera sees" />
            <Button Grid.Column="1" AutomationId="ReadButton"
                    Text="📖 Read" TabIndex="31"
                    Command="{Binding ReadCommand}"
                    Style="{StaticResource ActionButton}"
                    SemanticProperties.Description="Read"
                    SemanticProperties.Hint="Reads text visible to the camera" />
            <Button Grid.Column="2" AutomationId="FindButton"
                    Text="🔍 Find" TabIndex="32"
                    Command="{Binding FindCommand}"
                    Style="{StaticResource ActionButton}"
                    SemanticProperties.Description="Find"
                    SemanticProperties.Hint="Finds specific objects in the camera view" />
            <Button Grid.Row="1" AutomationId="AskButton"
                    Text="💬 Ask" TabIndex="33"
                    Command="{Binding AskCommand}"
                    Style="{StaticResource ActionButton}"
                    SemanticProperties.Description="Ask"
                    SemanticProperties.Hint="Asks the AI a question" />
            <Button Grid.Row="1" Grid.Column="1" AutomationId="PhotoButton"
                    Text="📸 Photo" TabIndex="34"
                    Command="{Binding PhotoCommand}"
                    Style="{StaticResource ActionButton}"
                    SemanticProperties.Description="Photo"
                    SemanticProperties.Hint="Takes a photo with the camera" />
        </Grid>
    </Grid>
</ContentPage>
