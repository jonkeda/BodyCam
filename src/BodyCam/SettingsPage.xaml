<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BodyCam.ViewModels"
             x:Class="BodyCam.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Shell.TabBarIsVisible="False"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Note -->
            <Label Text="Changes take effect on next session start."
                   FontSize="Caption" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" FontAttributes="Italic" />

            <!-- SECTION: Provider -->
            <Label Text="Provider" FontSize="Title" FontAttributes="Bold" Margin="0,8,0,0"
                   SemanticProperties.HeadingLevel="Level1" />

            <HorizontalStackLayout Spacing="16">
                <RadioButton AutomationId="ProviderOpenAiRadio"
                             Content="OpenAI" TabIndex="10"
                             IsChecked="{Binding IsOpenAi}"
                             CheckedChanged="OnOpenAiChecked"
                             SemanticProperties.Description="Use OpenAI provider" />
                <RadioButton AutomationId="ProviderAzureRadio"
                             Content="Azure" TabIndex="11"
                             IsChecked="{Binding IsAzure}"
                             CheckedChanged="OnAzureChecked"
                             SemanticProperties.Description="Use Azure OpenAI provider" />
            </HorizontalStackLayout>

            <!-- SECTION: Models (OpenAI only) -->
            <VerticalStackLayout Spacing="12" IsVisible="{Binding IsOpenAi}">
                <Label Text="Models" FontSize="Title" FontAttributes="Bold" Margin="0,8,0,0"
                       SemanticProperties.HeadingLevel="Level1" />

                <Label Text="Voice Model" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                <HorizontalStackLayout Spacing="8">
                    <Picker AutomationId="VoiceModelPicker" TabIndex="20"
                            ItemsSource="{Binding RealtimeModelOptions}"
                            ItemDisplayBinding="{Binding Label}"
                            SelectedItem="{Binding SelectedRealtimeModel}"
                            HorizontalOptions="FillAndExpand"
                            SemanticProperties.Description="Voice model" />
                    <Label AutomationId="RealtimeStatusLabel"
                           Text="{Binding RealtimeStatus}"
                           VerticalOptions="Center" FontSize="Small" />
                </HorizontalStackLayout>

                <Label Text="Chat Model" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                <HorizontalStackLayout Spacing="8">
                    <Picker AutomationId="ChatModelPicker" TabIndex="21"
                            ItemsSource="{Binding ChatModelOptions}"
                            ItemDisplayBinding="{Binding Label}"
                            SelectedItem="{Binding SelectedChatModel}"
                            HorizontalOptions="FillAndExpand"
                            SemanticProperties.Description="Chat model" />
                    <Label AutomationId="ChatStatusLabel"
                           Text="{Binding ChatStatus}"
                           VerticalOptions="Center" FontSize="Small" />
                </HorizontalStackLayout>

                <Label Text="Vision Model" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                <HorizontalStackLayout Spacing="8">
                    <Picker AutomationId="VisionModelPicker" TabIndex="22"
                            ItemsSource="{Binding VisionModelOptions}"
                            ItemDisplayBinding="{Binding Label}"
                            SelectedItem="{Binding SelectedVisionModel}"
                            HorizontalOptions="FillAndExpand"
                            SemanticProperties.Description="Vision model" />
                    <Label AutomationId="VisionStatusLabel"
                           Text="{Binding VisionStatus}"
                           VerticalOptions="Center" FontSize="Small" />
                </HorizontalStackLayout>

                <Label Text="Transcription Model" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                <HorizontalStackLayout Spacing="8">
                    <Picker AutomationId="TranscriptionModelPicker" TabIndex="23"
                            ItemsSource="{Binding TranscriptionModelOptions}"
                            ItemDisplayBinding="{Binding Label}"
                            SelectedItem="{Binding SelectedTranscriptionModel}"
                            HorizontalOptions="FillAndExpand"
                            SemanticProperties.Description="Transcription model" />
                    <Label AutomationId="TranscriptionStatusLabel"
                           Text="{Binding TranscriptionStatus}"
                           VerticalOptions="Center" FontSize="Small" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- SECTION: Azure Deployments (Azure only) -->
            <VerticalStackLayout Spacing="12" IsVisible="{Binding IsAzure}">
                <Label Text="Azure Deployments" FontSize="Title" FontAttributes="Bold" Margin="0,8,0,0"
                       SemanticProperties.HeadingLevel="Level1" />

                <Label Text="Endpoint" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                <Entry AutomationId="AzureEndpointEntry" TabIndex="30"
                       Text="{Binding AzureEndpoint}"
                       Placeholder="https://your-resource.cognitiveservices.azure.com"
                       SemanticProperties.Description="Azure endpoint URL" />

                <Label Text="API Version" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                <Entry AutomationId="AzureApiVersionEntry" TabIndex="31"
                       Text="{Binding AzureApiVersion}"
                       Placeholder="2025-04-01-preview"
                       SemanticProperties.Description="Azure API version" />

                <Label Text="Realtime Deployment" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                <HorizontalStackLayout Spacing="8">
                    <Entry AutomationId="AzureRealtimeDeploymentEntry" TabIndex="32"
                           Text="{Binding AzureRealtimeDeployment}"
                           Placeholder="my-realtime-deployment"
                           HorizontalOptions="FillAndExpand"
                           SemanticProperties.Description="Azure realtime deployment name" />
                    <Label Text="{Binding RealtimeStatus}"
                           VerticalOptions="Center" FontSize="Small" />
                </HorizontalStackLayout>

                <Label Text="Chat Deployment" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                <HorizontalStackLayout Spacing="8">
                    <Entry AutomationId="AzureChatDeploymentEntry" TabIndex="33"
                           Text="{Binding AzureChatDeployment}"
                           Placeholder="my-chat-deployment"
                           HorizontalOptions="FillAndExpand"
                           SemanticProperties.Description="Azure chat deployment name" />
                    <Label Text="{Binding ChatStatus}"
                           VerticalOptions="Center" FontSize="Small" />
                </HorizontalStackLayout>

                <Label Text="Vision Deployment" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                <HorizontalStackLayout Spacing="8">
                    <Entry AutomationId="AzureVisionDeploymentEntry" TabIndex="34"
                           Text="{Binding AzureVisionDeployment}"
                           Placeholder="my-vision-deployment"
                           HorizontalOptions="FillAndExpand"
                           SemanticProperties.Description="Azure vision deployment name" />
                    <Label Text="{Binding VisionStatus}"
                           VerticalOptions="Center" FontSize="Small" />
                </HorizontalStackLayout>


            </VerticalStackLayout>

            <!-- SECTION: Voice -->
            <Label Text="Voice Settings" FontSize="Title" FontAttributes="Bold" Margin="0,8,0,0"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label Text="Voice" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
            <Picker AutomationId="VoicePicker" TabIndex="40"
                    ItemsSource="{Binding VoiceOptions}"
                    SelectedItem="{Binding SelectedVoice}"
                    SemanticProperties.Description="Voice" />

            <Label Text="Turn Detection" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
            <Picker AutomationId="TurnDetectionPicker" TabIndex="41"
                    ItemsSource="{Binding TurnDetectionOptions}"
                    SelectedItem="{Binding SelectedTurnDetection}"
                    SemanticProperties.Description="Turn detection" />

            <Label Text="Noise Reduction" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
            <Picker AutomationId="NoiseReductionPicker" TabIndex="42"
                    ItemsSource="{Binding NoiseReductionOptions}"
                    SelectedItem="{Binding SelectedNoiseReduction}"
                    SemanticProperties.Description="Noise reduction" />

            <!-- SECTION: System Prompt -->
            <Label Text="System Instructions" FontSize="Title" FontAttributes="Bold" Margin="0,8,0,0"
                   SemanticProperties.HeadingLevel="Level1" />
            <Editor AutomationId="SystemInstructionsEditor" TabIndex="50"
                    Text="{Binding SystemInstructions}"
                    HeightRequest="100"
                    Placeholder="You are a helpful assistant."
                    SemanticProperties.Description="System instructions for the AI assistant" />

            <!-- SECTION: API Key -->
            <Label Text="API Key" FontSize="Title" FontAttributes="Bold" Margin="0,8,0,0"
                   SemanticProperties.HeadingLevel="Level1" />
            <HorizontalStackLayout Spacing="8">
                <Entry AutomationId="ApiKeyDisplay" TabIndex="60"
                       Text="{Binding ApiKeyDisplay}"
                       IsPassword="{Binding IsKeyVisible, Converter={StaticResource InvertBoolConverter}}"
                       IsReadOnly="True"
                       HorizontalOptions="FillAndExpand"
                       WidthRequest="200"
                       SemanticProperties.Description="API key, masked" />
                <Button AutomationId="ToggleKeyVisibilityButton" TabIndex="61"
                        Text="{Binding KeyToggleText}"
                        Command="{Binding ToggleKeyVisibilityCommand}"
                        WidthRequest="60" Padding="4"
                        BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                        TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}"
                        SemanticProperties.Description="Toggle key visibility"
                        SemanticProperties.Hint="Shows or hides the API key" />
                <Button AutomationId="ChangeApiKeyButton" TabIndex="62"
                        Text="Change" Command="{Binding ChangeApiKeyCommand}"
                        BackgroundColor="{AppThemeBinding Light=#512BD4, Dark=#7C4DFF}"
                        TextColor="White"
                        SemanticProperties.Description="Change API key" />
                <Button AutomationId="ClearApiKeyButton" TabIndex="63"
                        Text="Clear" Command="{Binding ClearApiKeyCommand}"
                        BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                        TextColor="{AppThemeBinding Light=#333, Dark=#E0E0E0}"
                        SemanticProperties.Description="Clear API key"
                        SemanticProperties.Hint="Removes the stored API key" />
            </HorizontalStackLayout>

            <!-- SECTION: Test Connection -->
            <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                <Button AutomationId="TestConnectionButton" TabIndex="64"
                        Text="Test Connection"
                        Command="{Binding TestConnectionCommand}"
                        IsEnabled="{Binding IsTesting, Converter={StaticResource InvertBoolConverter}}"
                        BackgroundColor="{AppThemeBinding Light=#512BD4, Dark=#7C4DFF}"
                        TextColor="White"
                        SemanticProperties.Description="Test connection"
                        SemanticProperties.Hint="Tests the API connection with current settings" />
                <Label AutomationId="ConnectionStatusLabel"
                       Text="{Binding ConnectionStatus}"
                       VerticalOptions="Center"
                       FontSize="Small" />
            </HorizontalStackLayout>

            <!-- SECTION: Camera -->
            <Label Text="Camera" FontSize="Title" FontAttributes="Bold" Margin="0,8,0,0"
                   SemanticProperties.HeadingLevel="Level1" />
            <Label Text="Camera Source" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
            <Picker AutomationId="CameraSourcePicker" TabIndex="70"
                    ItemsSource="{Binding CameraProviders}"
                    ItemDisplayBinding="{Binding DisplayName}"
                    SelectedItem="{Binding SelectedCameraProvider}"
                    SemanticProperties.Description="Camera source" />

            <!-- SECTION: Audio Input -->
            <Label Text="Audio Input" FontSize="Title" FontAttributes="Bold" Margin="0,8,0,0"
                   SemanticProperties.HeadingLevel="Level1" />
            <Label Text="Microphone Source" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
            <Picker AutomationId="AudioInputPicker" TabIndex="80"
                    ItemsSource="{Binding AudioInputProviders}"
                    ItemDisplayBinding="{Binding DisplayName}"
                    SelectedItem="{Binding SelectedAudioInputProvider}"
                    SemanticProperties.Description="Microphone source" />

            <!-- SECTION: Audio Output -->
            <Label Text="Audio Output" FontSize="Title" FontAttributes="Bold" Margin="0,8,0,0"
                   SemanticProperties.HeadingLevel="Level1" />
            <Label Text="Speaker" FontSize="Small" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
            <Picker AutomationId="AudioOutputPicker" TabIndex="90"
                    ItemsSource="{Binding AudioOutputProviders}"
                    ItemDisplayBinding="{Binding DisplayName}"
                    SelectedItem="{Binding SelectedAudioOutputProvider}"
                    SemanticProperties.Description="Speaker" />

            <!-- SECTION: Debug -->
            <Label Text="Debug" FontSize="Title" FontAttributes="Bold" Margin="0,8,0,0"
                   SemanticProperties.HeadingLevel="Level1" />

            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                <Label Text="Debug Mode" VerticalOptions="Center" Grid.Row="0" Grid.Column="0" />
                <Switch AutomationId="DebugModeSwitch" TabIndex="100" IsToggled="{Binding DebugMode}" Grid.Row="0" Grid.Column="1"
                        SemanticProperties.Description="Debug mode" />

                <Label Text="Show Token Counts" VerticalOptions="Center" Grid.Row="1" Grid.Column="0" />
                <Switch AutomationId="ShowTokenCountsSwitch" TabIndex="101" IsToggled="{Binding ShowTokenCounts}" Grid.Row="1" Grid.Column="1"
                        SemanticProperties.Description="Show token counts" />

                <Label Text="Show Cost Estimate" VerticalOptions="Center" Grid.Row="2" Grid.Column="0" />
                <Switch AutomationId="ShowCostEstimateSwitch" TabIndex="102" IsToggled="{Binding ShowCostEstimate}" Grid.Row="2" Grid.Column="1"
                        SemanticProperties.Description="Show cost estimate" />
            </Grid>

            <!-- SECTION: Tool Settings -->
            <Label Text="Tool Settings" FontSize="Title" FontAttributes="Bold" Margin="0,16,0,0"
                   SemanticProperties.HeadingLevel="Level1" />
            <Label Text="Configure individual tool behavior." FontSize="Caption" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />

            <CollectionView ItemsSource="{Binding ToolSettingsSections}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ToolSettingsSection">
                        <VerticalStackLayout Padding="0,12,0,0">
                            <Label Text="{Binding DisplayName}" FontSize="Body" FontAttributes="Bold" />
                            <Label Text="{Binding Description}" FontSize="Caption" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" Margin="0,0,0,4" />
                            <CollectionView ItemsSource="{Binding Items}"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ToolSettingItem">
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                            <Label Text="{Binding Label}" VerticalOptions="Center" />
                                            <Switch IsToggled="{Binding BoolValue}"
                                                    IsVisible="{Binding IsBoolean}"
                                                    SemanticProperties.Description="{Binding Label}"
                                                    Grid.Column="1" />
                                            <Entry Text="{Binding StringValue}"
                                                   IsVisible="{Binding IsInteger}"
                                                   Keyboard="Numeric"
                                                   WidthRequest="80"
                                                   SemanticProperties.Description="{Binding Label}"
                                                   Grid.Column="1" />
                                            <Entry Text="{Binding StringValue}"
                                                   IsVisible="{Binding IsText}"
                                                   WidthRequest="200"
                                                   SemanticProperties.Description="{Binding Label}"
                                                   Grid.Column="1" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
